APP_NAME=mmattend-backend
APP_ENV=development
API_V1_PREFIX=/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db.example.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=
SUPABASE_STUDENT_IMAGES_BUCKET=student-images
SUPABASE_FACE_TRAINING_BUCKET=face-training-images
SUPABASE_REPORTS_BUCKET=reports
ATTENDANCE_CONFIDENCE_THRESHOLD=0.8
SIGNED_UPLOAD_URL_TTL_SECONDS=7200